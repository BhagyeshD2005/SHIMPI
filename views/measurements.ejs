<%- include('partials/header') %>
<div class="row g-4">
  <div class="col-lg-5">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h2 class="h4 mb-3">Add Measurement Profile</h2>
        <form method="post" action="/measurements" class="vstack gap-3">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Profile Name</label>
              <input type="text" name="profileName" class="form-control" placeholder="Self, Father, Mother" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Gender</label>
              <select name="gender" class="form-select">
                <option value="">Select</option>
                <option>Male</option>
                <option>Female</option>
                <option>Unisex</option>
              </select>
            </div>
          </div>
          <div class="row g-2">
            <div class="col-4"><label class="form-label">Neck</label><input name="neck" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Chest</label><input name="chest" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Waist</label><input name="waist" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Hip</label><input name="hip" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Shoulder</label><input name="shoulder" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Sleeve</label><input name="sleeveLength" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Shirt Length</label><input name="shirtLength" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Inseam</label><input name="inseam" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Thigh</label><input name="thigh" type="number" step="0.1" class="form-control"></div>
            <div class="col-4"><label class="form-label">Calf</label><input name="calf" type="number" step="0.1" class="form-control"></div>
          </div>
          <div>
            <label class="form-label">Notes</label>
            <textarea name="notes" class="form-control" rows="3" placeholder="Fit preferences, posture notes, etc."></textarea>
          </div>
          <button class="btn btn-dark">Save Measurements</button>
        </form>
      </div>
    </div>
  </div>
  <div class="col-lg-7">
    <div class="section-heading mb-3">
      <h2>Your Measurement Profiles</h2>
      <span class="text-muted"><%= measurements.length %> saved</span>
    </div>
    <div class="row g-3">
      <% measurements.forEach(m => { %>
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
              <h5><%= m.profileName %></h5>
              <div class="small text-muted mb-2"><%= m.gender %></div>
              <div class="row small">
                <div class="col-6">Chest: <strong><%= m.chest %></strong></div>
                <div class="col-6">Waist: <strong><%= m.waist %></strong></div>
                <div class="col-6">Shoulder: <strong><%= m.shoulder %></strong></div>
                <div class="col-6">Sleeve: <strong><%= m.sleeveLength %></strong></div>
              </div>
              <form method="post" action="/measurements/<%= m.id %>/delete" class="mt-3">
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
