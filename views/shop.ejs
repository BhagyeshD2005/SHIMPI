<%- include('partials/header') %>
<div class="section-heading mb-3">
  <h2>Shop Collection</h2>
  <p class="text-muted mb-0">Select a design and start your custom tailoring journey.</p>
</div>

<div class="row g-4">
  <% products.forEach(product => { %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 shadow-sm border-0 product-card">
        <img src="<%= product.images && product.images[0] ? product.images[0] : 'https://via.placeholder.com/900x600?text=SHIMPI' %>" class="card-img-top product-image" alt="<%= product.name %>">
        <div class="card-body d-flex flex-column">
          <div class="small text-uppercase text-muted"><%= product.category %></div>
          <h5 class="card-title"><%= product.name %></h5>
          <p class="card-text text-muted"><%= product.description %></p>
          <div class="mt-auto d-flex justify-content-between align-items-center">
            <strong><%= formatCurrency(product.basePrice) %></strong>
            <% if (currentUser) { %>
              <a class="btn btn-dark btn-sm" href="/product/<%= product.id %>">Customize</a>
            <% } else { %>
              <a class="btn btn-dark btn-sm" href="/login">Login</a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>
